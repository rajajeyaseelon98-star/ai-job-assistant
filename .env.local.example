# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI: use either Gemini or OpenAI (resume analysis uses Gemini if GEMINI_API_KEY is set)
# Gemini (Google AI) - get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (optional fallback / other features)
OPENAI_API_KEY=sk-your-openai-key
