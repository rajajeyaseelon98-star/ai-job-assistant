# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Production canonical URL (no trailing slash). Required on Vercel for correct Google OAuth / email / password-reset
# redirects when users have a PWA installed from localhost or mixed origins. Omit locally so redirects use localhost.
# NEXT_PUBLIC_APP_URL=https://ai-job-assistant-six-rho.vercel.app
# Optional: server-only; enables PATCH /api/user/role, and inserts recipient in-app notifications on new messages (RLS otherwise blocks cross-user notification rows). Keep secret — never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Messaging: max GET /api/messages/recipient-search requests per minute per user (default 45). Logs JSON lines with event recipient_search_rate_limited on 429.
# RECIPIENT_SEARCH_RATE_LIMIT_MAX=45

# AI: use either Gemini or OpenAI (resume analysis uses Gemini if GEMINI_API_KEY is set)
# Gemini (Google AI) - get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (optional fallback / other features)
OPENAI_API_KEY=sk-your-openai-key

# Adzuna Job Board API (optional — enables real job search in Auto Job Finder & Auto-Apply)
# Get keys at https://developer.adzuna.com/
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
