{
  "name": "ai-job-assistant",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test e2e/resume-flow.spec.ts e2e/auto-apply.spec.ts e2e/recruiter-flow.spec.ts",
    "test:e2e:real:setup": "playwright test --project=real-setup",
    "test:e2e:real:jobseeker:desktop": "playwright test --project=real-jobseeker-desktop",
    "test:e2e:real:recruiter:desktop": "playwright test --project=real-recruiter-desktop",
    "test:e2e:real:jobseeker:mobile": "playwright test --project=real-jobseeker-mobile",
    "test:e2e:real:recruiter:mobile": "playwright test --project=real-recruiter-mobile",
    "test:e2e:real:smoke": "npm run test:e2e:real:setup && npm run test:e2e:real:jobseeker:desktop && npm run test:e2e:real:recruiter:desktop && npm run test:e2e:real:jobseeker:mobile && npm run test:e2e:real:recruiter:mobile",
    "test:api": "playwright test -c playwright.api.config.ts",
    "test:e2e:full-inventory-pages": "playwright test e2e/full-site-page-inventory-mock.spec.ts --project=chromium",
    "test:all:qa": "npm run test:e2e:critical && npm run test:api",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.95.2",
    "docx": "^9.6.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.8.0",
    "next": "^15.5.15",
    "next-pwa": "^5.6.0",
    "openai": "^4.73.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-markdown": "^10.1.0",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@types/node": "^22.10.1",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
