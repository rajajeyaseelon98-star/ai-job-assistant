# Playwright real-user regression (local only)
#
# Copy to `.env.e2e.local` (gitignored) and fill in real credentials.
#
# IMPORTANT:
# - Do NOT commit `.env.e2e.local`
# - Tests auto-skip real-user projects if these are missing

E2E_JOBSEEKER_EMAIL=
E2E_JOBSEEKER_PASSWORD=

E2E_RECRUITER_EMAIL=
E2E_RECRUITER_PASSWORD=

# Optional but recommended: enables a stable server-side login for Playwright real-user mode.
# This is used only in non-production by `/api/internal/e2e-password-login` and avoids flaky
# client-side cookie persistence in `next dev`.
E2E_INTERNAL_AUTH_SECRET=

# Optional: override Playwright base URL (otherwise uses http://localhost:<PLAYWRIGHT_PORT>)
# Use the same hostname your browser session expects (localhost vs 127.0.0.1 affects Supabase cookies).
# PLAYWRIGHT_BASE_URL=http://localhost:3010

